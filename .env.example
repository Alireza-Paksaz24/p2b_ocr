# Enable SQLite history (true/false)
ENABLE_DB=false

# Database URL (only used when ENABLE_DB=true)
DATABASE_URL=sqlite+aiosqlite:///./ocr_history.db

# Local storage directories
MODELS_DIR=./models_cache
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Hugging Face token (optional, for gated models)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Maximum upload size per file in MB
MAX_UPLOAD_MB=200